# Ignore python cache files
__pycache__
*.pyc

# Ignore virtual environment
venv


# Ignore database files
database.db

# Ignore logs
*.log

# Ignore IDE files
.idea
.vscode

# Ignore temporary files
*~

# Ignore hypothesis
.hypothesis/

# Environment files - tracked via git-crypt (see .gitattributes)
# Block any accidental .env files NOT covered by git-crypt
*.env.local
.env.*.local